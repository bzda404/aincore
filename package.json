{
  "name": "hearth",
  "version": "1.0.0-rc.1",
  "description": "Hearth — 本地 AI 算力平台中枢",
  "main": "./out/main/index.js",
  "private": true,
  "homepage": "https://github.com/bzda404/hearth",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:mac": "electron-rebuild && electron-vite build && electron-builder --mac --publish never",
    "build:mac:x64": "electron-rebuild && electron-vite build && electron-builder --mac --x64 --publish never",
    "build:mac:arm64": "electron-rebuild && electron-vite build && electron-builder --mac --arm64 --publish never",
    "build:win:x64": "electron-rebuild && electron-vite build && electron-builder --win --x64 --publish never",
    "build:win:arm64": "electron-rebuild && electron-vite build && electron-builder --win --arm64 --publish never",
    "build:linux": "electron-rebuild && electron-vite build && electron-builder --linux --publish never",
    "start": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --cache .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "better-sqlite3": "^12.2.0",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "element-plus": "^2.14.0",
    "pinia": "^3.0.4",
    "vue": "3.5.34",
    "vue-i18n": "^10.0.7",
    "vue-router": "^4.6.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.19",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^3.2.6",
    "cross-env": "^10.1.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-vue": "^10.9.1",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^7.3.3",
    "vitest": "^3.2.6",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
